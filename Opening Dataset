    m = re.search(
        r"wrf3d_d01_(\d{4}-\d{2}-\d{2}_\d{2}:\d{2}:\d{2})",
        os.path.basename(path)
    )
    if m:
        return pd.to_datetime(m.group(1), format="%Y-%m-%d_%H:%M:%S")
    return pd.NaT

#Variable Selection
#To further minimze the computation expense of opening and saving this data, we can subset the dataset by only variables we will use for our project
def preprocess(ds):
    # keep only needed variables
    ds = ds[["Z", "P", "TK", "XLAT", "XLON"]] #Z = geopotential height, P = pressure, TK = temperature in kelvin, XLAT/XLON are from geo files and make data plotable 

    # subset to ECONUS by index
    ds = ds.isel(west_east=slice(107, None))

    # get time from filename
    src = ds.encoding.get("source", "")
    file_time = get_file_time(src)

    # assign filename time
    ds = ds.assign_coords(time=("Time", [file_time]))
    ds = ds.swap_dims({"Time": "time"})

    return ds

#Temporal Chunking
#Since we are only working on a certain period, we will chunk the data only by the years we will use. This is more computationally efficient than opening the entire 43 year dataset. 
years = range(2008, 2025)

for wy in tqdm(years, desc="Water years"):
    file_list = sorted(glob.glob(os.path.join(base_dir, f"WY{wy}", "wrf3d_d01_*")))

    if not file_list:
        print(f"No files found for WY{wy}")
        continue

#Opening dataset and saving
 ds_chunk = xr.open_mfdataset(
        tqdm(file_list, desc=f"Opening files WY{wy}", leave=False),
        preprocess=preprocess,
        combine="nested",
        concat_dim="time",
        parallel=False,
        engine="netcdf4",
        chunks={"time": 1}
    )

    for coord_name in geo_econus.data_vars:
        if geo_econus[coord_name].dims == ("south_north", "west_east"):
            ds_chunk[coord_name] = geo_econus[coord_name]

    ds_chunk = ds_chunk.sortby("time")

    out_file = os.path.join(out_dir, f"wrf3d_ECONUS_Z_P_TK_WY{wy}.nc")

    print(f"Saving {out_file}")
    ds_chunk.to_netcdf(out_file)
    ds_chunk.close() 
